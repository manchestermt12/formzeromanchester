{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "formzeromanchester",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "formzero",
			"database_id": "b9623157-1506-41ed-8bb3-78337c0ffe18",
		}
	]
}